{
  "name": "@loopress/cli",
  "description": "CLI tool for syncing WordPress CodeSnippets, styles, and menus via the REST API",
  "version": "0.5.0",
  "author": "jean-smaug",
  "bin": {
    "loopress": "bin/run.js",
    "lps": "bin/run.js"
  },
  "bugs": {
    "url": "https://github.com/loopress/loopress/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@oclif/core": "^4.11.11",
    "@oclif/plugin-help": "^6.2.52",
    "@oclif/plugin-plugins": "^5.4.80",
    "glob": "13.0.6",
    "got": "^15.0.7",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.20",
    "@types/node": "26.0.1",
    "eslint": "^9",
    "eslint-config-oclif": "^6.0.174",
    "eslint-config-prettier": "^10",
    "oclif": "^4.23.22",
    "prettier": "3.9.1",
    "shx": "^0.4.0",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/loopress/loopress",
  "keywords": [
    "oclif"
  ],
  "license": "MPL-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "lps",
    "binAliases": [
      "loopress",
      "lps"
    ],
    "dirname": "loopress",
    "commands": "./dist/commands",
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopress/loopress.git"
  },
  "scripts": {
    "watch": "tsc -b --watch",
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "vitest run",
    "version": "oclif readme && git add README.md",
    "format": "prettier . --write"
  },
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  }
}
