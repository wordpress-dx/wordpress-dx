{
  "name": "@loopress/wordpress-plugin",
  "version": "2026.6.0",
  "private": true,
  "scripts": {
    "prebuild": "cp node_modules/@loopress/assets/loopress-logo-full-white.svg assets/logo.svg",
    "build": "wp-scripts build frontend/index.tsx",
    "dev": "wp-scripts start frontend/index.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "zip": "wp-scripts plugin-zip",
    "pack": "composer install --no-dev && pnpm run build && pnpm run zip",
    "postpack": "composer install",
    "version": "node scripts/sync-version.js && git add loopress-plugin.php"
  },
  "files": [
    "assets",
    "build",
    "src",
    "vendor",
    "composer.json",
    "loopress-plugin.php"
  ],
  "dependencies": {
    "@loopress/assets": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@wordpress/components": "^36.0.1",
    "@wordpress/element": "^8.0.0",
    "@wordpress/scripts": "32.5.1",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "url-loader": "^4.1.1",
    "vitest": "^4.1.9"
  }
}
