{
  "name": "loopress",
  "version": "2026.6.0",
  "private": true,
  "scripts": {
    "prebuild": "cp node_modules/@loopress/assets/loopress-logo-full-white.svg assets/logo.svg",
    "build": "wp-scripts build frontend/index.tsx",
    "dev": "wp-scripts start frontend/index.tsx",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "zip": "wp-scripts plugin-zip",
    "pack": "composer install --no-dev && bun run build && bun run zip",
    "postpack": "composer install"
  },
  "files": ["assets", "build", "src", "vendor", "composer.json", "loopress-plugin.php"],
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@loopress/assets": "file:../assets",
    "react-hook-form": "^7.78.0",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "~18",
    "@types/react-dom": "~18",
    "@wordpress/components": "^35.0.0",
    "@wordpress/element": "^8.0.0",
    "@wordpress/scripts": "32.4.0",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3"
  }
}
