---
import "../styles.css";
import faviconUrl from "@loopress/assets/loopress-logo-black.svg?url";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  structuredData?: object;
}

const {
  title = "Loopress - Make WordPress reproducible",
  description = "Loopress brings modern development workflows to WordPress. Version configuration, manage dependencies, review changes, deploy with confidence.",
  canonical,
  ogTitle = "Loopress - Make WordPress reproducible",
  ogDescription = "Modern development workflows for WordPress. Configuration as code, version control, reproducible environments.",
  structuredData,
} = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://loopress.dev/#organization",
      name: "Loopress",
      url: "https://loopress.dev",
      logo: "https://cdn.jsdelivr.net/npm/@loopress/assets@1.0.0/loopress-logo-black.svg",
      sameAs: ["https://github.com/loopress"],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        url: "https://loopress.dev/contact",
      },
    },
    {
      "@type": "WebSite",
      "@id": "https://loopress.dev/#website",
      name: "Loopress",
      url: "https://loopress.dev",
      publisher: { "@id": "https://loopress.dev/#organization" },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          document.documentElement.classList.toggle("dark", t !== "light");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
