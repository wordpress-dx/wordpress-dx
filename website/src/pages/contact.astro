---
import Layout from "@/layouts/Layout.astro";
import { Nav } from "@/components/landing/Nav";
import { Footer } from "@/components/landing/Footer";
import ContactForm from "@/components/ContactForm";
---

<Layout
  title="Contact the Loopress Team - Partnerships and Support"
  description="Get in touch with the Loopress team for partnership requests, trademark inquiries, or general support. We'll get back to you as soon as possible."
  canonical="https://loopress.dev/contact"
>
  <div class="min-h-screen bg-background text-foreground">
    <Nav client:load />
    <main class="mx-auto max-w-xl px-6 py-24">
      <div class="mb-10">
        <h1 class="text-2xl font-semibold tracking-tight">Contact</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          A question, a partnership request, or a trademark inquiry? Send us a message and we will
          get back to you.
        </p>
      </div>
      <h2 class="sr-only">Contact form</h2>
      <ContactForm client:load />
      <p class="mt-8 text-center text-xs text-muted-foreground">
        For trademark or brand asset requests, see the{" "}
        <a href="/brand-assets" class="underline underline-offset-2 hover:text-foreground">
          usage policy
        </a>.
      </p>
    </main>
    <Footer />
  </div>
</Layout>
